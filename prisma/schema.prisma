datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admin")
}

model Service {
  id               Int      @id @default(autoincrement())
  title            String
  slug             String   @unique
  shortDescription String   @db.Text @map("short_description")
  description      String   @db.LongText
  image            String?
  status           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("services")
}

model Gallery {
  id        Int      @id @default(autoincrement())
  title     String
  image     String
  category  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("gallery")
}

model Order {
  id          Int      @id @default(autoincrement())
  billingId   String   @unique @map("billing_id")
  trackingId  String?  @map("tracking_id")
  orderName   String   @map("order_name")
  mobile      String?
  orderEmail  String?  @map("order_email")
  description String?  @db.Text
  status      String   @default("Pending")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("orders")
}